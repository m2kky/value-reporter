# Copy this file to .env and fill your real values.
# Keep .env private.

# Global output location for generated monthly reports.
REPORT_OUTPUT_DIR=outputs
CLIENTS_CONFIG=clients.json

# Ads reporting token. Use a User or System User token with ads_read/read_insights
# and access to the ad accounts below. Do not use a Page access token here.
META_ADS_ACCESS_TOKEN=replace_with_long_lived_ads_token
META_API_VERSION=v25.0

# Demo client's two Meta ad accounts.
META_AD_ACCOUNT_ID=act_1234567890
META_AD_ACCOUNT_ID_2=act_9876543210

# Organic page/Instagram reporting. If META_ORGANIC_ACCESS_TOKEN is empty,
# the pipeline can fall back to META_PAGE_ACCESS_TOKEN, then the legacy
# META_ACCESS_TOKEN, then META_ADS_ACCESS_TOKEN if present.
META_ORGANIC_ACCESS_TOKEN=replace_with_user_or_page_token_for_organic
META_PAGE_ID=1234567890
META_PAGE_ACCESS_TOKEN=replace_with_page_token

# Optional: set this if the Page lookup does not expose instagram_business_account.
META_INSTAGRAM_ACCOUNT_ID=17841400000000000
META_IG_ACCESS_TOKEN=replace_with_user_token_for_instagram_insights

# Optional AI narrative layer.
# When AI_REPORT_ENABLED=true, report data is sent to the OpenAI API.
AI_REPORT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
